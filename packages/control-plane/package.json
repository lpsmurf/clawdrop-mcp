{
  "name": "@clawdrop/control-plane",
  "version": "1.0.0",
  "description": "Clawdrop MCP Server - Control Plane for Agent Deployment Orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "CLAWDROP_MODE=mcp node --loader ts-node/esm src/index.ts",
    "api": "CLAWDROP_MODE=api node --loader ts-node/esm src/index.ts",
    "both": "CLAWDROP_MODE=both node --loader ts-node/esm src/index.ts",
    "cli": "node --loader ts-node/esm src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "pino": "^8.19.0",
    "pino-pretty": "^10.2.3",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
