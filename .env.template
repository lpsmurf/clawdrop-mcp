# ============================================================================
# CLAWDROP ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git (it contains secrets)

# ============================================================================
# VPS INFRASTRUCTURE (User-Provided Names)
# ============================================================================
# See VPS_HOSTS.md for full inventory and documentation

# KIMI VPS (Provisioner - Deployment Control)
# Runs: HFSP provisioner (port 3001) + clawdrop-mcp control plane
# IP: 187.124.170.113
KIMI_VPS_HOST=187.124.170.113
KIMI_VPS_USER=root
KIMI_VPS_SSH_KEY=${HOME}/.ssh/id_ed25519_hfsp_provisioner

# TENANT VPS (Compute - Agent Docker Runtime)
# Runs: Docker daemon + deployed agent containers
# IP: 187.124.173.69
TENANT_VPS_HOST=187.124.173.69
TENANT_VPS_USER=root
TENANT_VPS_SSH_KEY=${HOME}/.ssh/id_ed25519_187_124_173_69

# IRIS VPS (API Gateway - Optional)
# Runs: External API endpoints / MCP server
# IP: 187.124.174.137
IRIS_VPS_HOST=187.124.174.137
IRIS_VPS_USER=root

# PIERCALITO VPS (API Backup - Optional)
# IP: 72.62.239.63
PIERCALITO_VPS_HOST=72.62.239.63
PIERCALITO_VPS_USER=root

# SATOSHICLERK VPS (Staging - Optional)
# IP: 76.13.157.84
SATOSHICLERK_VPS_HOST=76.13.157.84
SATOSHICLERK_VPS_USER=root

# SSH Configuration
SSH_KEY_PATH=${HOME}/.ssh/id_ed25519_hfsp_provisioner
SSH_TIMEOUT=10000
SSH_STRICT_HOST_CHECK=no

# ============================================================================
# HFSP PROVISIONER CONFIGURATION
# ============================================================================

# HFSP API URL (runs on KIMI_VPS_HOST:3001)
HFSP_URL=http://187.124.170.113:3001
HFSP_API_KEY=your_hfsp_api_key_here
HFSP_PORT=3001

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================

# OpenClaw Docker image
OPENCLAW_IMAGE=ghcr.io/clawdrop/openclaw:latest

# Docker registry credentials (if using private registry)
DOCKER_REGISTRY_URL=ghcr.io
DOCKER_REGISTRY_USER=your_username
DOCKER_REGISTRY_TOKEN=your_token

# ============================================================================
# SOLANA / BLOCKCHAIN CONFIGURATION
# ============================================================================

# Solana RPC Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Helius API (for Solana devnet verification)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_DEVNET_RPC=https://devnet.helius-rpc.com

# Agent wallet configuration
CLAWDROP_WALLET_ADDRESS=your_solana_wallet_here
CLAWDROP_WALLET_SECRET=${HOME}/.solana/id.json

# ============================================================================
# FLIGHT / TRAVEL BUNDLE CONFIGURATION
# ============================================================================

# Duffel API (Flight search & booking)
DUFFEL_API_TOKEN=DUFFEL_TEST_TOKEN_REDACTED
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_VERSION=v2

# Amadeus API (Travel partner - Phase 3)
AMADEUS_CLIENT_ID=your_client_id
AMADEUS_CLIENT_SECRET=your_client_secret
AMADEUS_API_BASE_URL=https://test.api.amadeus.com

# Gnosis Pay (Safe wallet + Visa card for crypto spending)
GNOSIS_PAY_API_KEY=your_gnosis_key
GNOSIS_SAFE_ADDRESS=your_safe_address

# Hotel API (if needed)
BOOKING_COM_API_KEY=your_booking_key

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (for agent state, subscriptions, billing)
DATABASE_URL=sqlite:///./clawdrop.db
DATABASE_ENCRYPT_KEY=your_encryption_key_here

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=info
DEBUG=false
SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# TESTING
# ============================================================================

TEST_MODE=false
TEST_AGENT_WALLET=your_test_wallet
MOCK_DUFFEL=false
MOCK_PAYMENT=false

# ============================================================================
# SECURITY & FEATURE FLAGS
# ============================================================================

ENABLE_PAYMENT_VERIFICATION=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGS=true
API_KEY_AUTH_REQUIRED=true

# Feature flags
FF_MULTI_BUNDLE_SUPPORT=true
FF_DOCKER_DEPLOYMENT=true
FF_SOLANA_PAYMENTS=true
FF_GNOSIS_PAY=false
